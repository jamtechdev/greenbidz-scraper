# ─── Database (MySQL) ───────────────────────────────────────────────
# This project uses MySQL (not PostgreSQL). The driver is mysql2.
# Copy this file to `.env` and fill in your own values.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=product_monitor
DB_USERNAME=root
DB_PASSWORD=

# ─── Crawler behaviour ──────────────────────────────────────────────
CRAWL_INTERVAL_HOURS=2
DOWNLOAD_IMAGES=true
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Scrape scope:
#   true  = only scrape products not yet scraped (new products). [default]
#   false = re-scrape every discovered product each cycle (refresh existing too).
ONLY_NEW_PRODUCTS=true

# Max products (scraped + unscraped) recorded per site/profile. Discovery stops
# creating new rows for a profile once it hits this cap.
MAX_PRODUCTS_PER_PROFILE=1000

# ─── Puppeteer ──────────────────────────────────────────────────────
# Set HEADLESS=false to watch the browser while debugging selectors.
HEADLESS=true
PAGE_TIMEOUT_MS=30000
NAV_WAIT_UNTIL=networkidle2

# ─── Paths (relative to project root) ───────────────────────────────
DOWNLOADS_DIR=downloads
LOGS_DIR=logs
PROFILES_DIR=profiles

# ─── Web admin API ──────────────────────────────────────────────────
# Backend API/server port. The Vite frontend (port 5173) proxies /api here.
WEB_PORT=4000

# ─── Listing pages to crawl (comma separated) ───────────────────────
# Optional seed list; profiles created in the UI carry their own listingUrls.
LISTING_URLS=https://example.com/products
