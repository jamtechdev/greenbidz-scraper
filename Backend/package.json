{
  "name": "product-monitor",
  "version": "1.0.0",
  "description": "Auto-detecting product scraper with JSON mapping profiles, Puppeteer stealth crawling, MySQL storage, and a 2-hour scheduler.",
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node main.js",
    "setup": "node setup.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "db:seed-profiles": "node scripts/seed-profiles.mjs",
    "manual-run": "node manual-run.js",
    "create-mapping": "node manual-mapping/create-profile.js",
    "edit-mapping": "node manual-mapping/edit-profile.js",
    "validate-mappings": "node manual-mapping/validate-profile.js",
    "manual-override": "node manual-run.js --override",
    "dev": "nodemon server.js",
    "share": "cloudflared tunnel --url http://localhost:5173 --no-autoupdate",
    "recon": "node scripts/recon.js"
  },
  "keywords": [
    "scraper",
    "puppeteer",
    "mysql",
    "crawler",
    "product-monitor"
  ],
  "author": "GreenBidz",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "mysql2": "^3.11.0",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.14",
    "prompts": "^2.4.2",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "sequelize-cli": "^6.6.5"
  }
}
