const path = require('path');

// Tells sequelize-cli where the (CommonJS) config, migrations, seeders, and
// models live. Migrations/seeders are .cjs because the package is ESM
// ("type":"module") and the CLI loads these files via require().
module.exports = {
  config: path.resolve(__dirname, 'database', 'config.cjs'),
  'models-path': path.resolve(__dirname, 'models'),
  'migrations-path': path.resolve(__dirname, 'database', 'migrations'),
  'seeders-path': path.resolve(__dirname, 'database', 'seeders'),
};
